# Ed25519 PKCS#8 private key (PEM). Use \n for newlines in a single line, or rely on multiline .env support.
# OUT_OF_SITE_ED25519_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# SPKI DER of the matching public key, standard Base64 (e.g. openssl ... -outform DER | base64).
# PUBLIC_OUT_OF_SITE_ED25519_SPKI_B64=

# UTF-8 symmetric secret for HMAC-SHA256 (`hash`) on kind=ssr and kind=giscus out-of-site links (same string in browser bundle).
# PUBLIC_OUTBOUND_LINK_HMAC_KEY=
