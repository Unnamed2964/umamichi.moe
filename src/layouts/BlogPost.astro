---
import BaseHead from '../components/BaseHead.astro';
import { ArticleLayout } from '../components/chakra/ArticleLayout';

type LayoutData = {
	title?: string;
	description?: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: {
		src: string;
	};
};

const pageData: LayoutData = 'frontmatter' in Astro.props
	? Astro.props.frontmatter
	: Astro.props;

const { title, description, pubDate, updatedDate, heroImage } = pageData;
const currentPath = Astro.url.pathname;
const formattedPubDate = pubDate
	? new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(pubDate)
	: undefined;
const formattedUpdatedDate = updatedDate
	? new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(updatedDate)
	: undefined;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<ArticleLayout
			currentPath={currentPath}
			title={title}
			pubDate={formattedPubDate}
			updatedDate={formattedUpdatedDate}
			heroImage={heroImage ? { src: heroImage.src } : undefined}
		>
			<slot />
		</ArticleLayout>
	</body>
</html>
