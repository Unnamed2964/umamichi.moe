---
import BaseHead from '../components/BaseHead.astro';
import { ArticleLayout } from '../components/chakra/ArticleLayout';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

type LayoutData = {
	title?: string;
	description?: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: {
		src: string;
	};
};

type TocHeading = {
	depth: number;
	slug: string;
	text: string;
};

type PostListItem = {
	href: string;
	id: string;
	title: string;
};

const pageData: LayoutData = 'frontmatter' in Astro.props
	? Astro.props.frontmatter
	: Astro.props;
const headings = 'headings' in Astro.props ? (Astro.props.headings as TocHeading[]) : undefined;
const articleList = 'articleList' in Astro.props ? (Astro.props.articleList as PostListItem[]) : undefined;
const currentEntryId = 'currentEntryId' in Astro.props ? (Astro.props.currentEntryId as string) : undefined;

const title = pageData.title ?? SITE_TITLE;
const description = pageData.description ?? SITE_DESCRIPTION;
const { pubDate, updatedDate, heroImage } = pageData;
const currentPath = Astro.url.pathname;
const formattedPubDate = pubDate
	? new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(pubDate)
	: undefined;
const formattedUpdatedDate = updatedDate
	? new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(updatedDate)
	: undefined;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<ArticleLayout
			articleList={articleList}
			currentPostId={currentEntryId}
			currentPath={currentPath}
			headings={headings}
			title={title}
			pubDate={formattedPubDate}
			updatedDate={formattedUpdatedDate}
			heroImage={heroImage ? { src: heroImage.src } : undefined}
		>
			<slot />
		</ArticleLayout>

		<script is:inline>
			const toc = document.querySelector('[data-toc]');
			if (toc) {
				const links = Array.from(toc.querySelectorAll('[data-toc-link]'));
				const headings = links
					.map((link) => {
						const slug = link.getAttribute('data-toc-link');
						if (!slug) return null;

						const heading = document.getElementById(slug);
						if (!heading) return null;

						return { slug, link, heading };
					})
					.filter(Boolean);

				if (headings.length > 0) {
					const setActive = (slug) => {
						for (const item of headings) {
							if (item.slug === slug) {
								item.link.setAttribute('aria-current', 'location');
								item.link.scrollIntoView({ block: 'nearest', inline: 'nearest' });
							} else {
								item.link.removeAttribute('aria-current');
							}
						}
					};

					const pickActiveSlug = () => {
						const headerOffset = Number.parseFloat(
							getComputedStyle(document.documentElement).getPropertyValue('--site-header-offset'),
						) || 0;
						const activationY = headerOffset + 32;

						let current = headings[0].slug;

						for (const item of headings) {
							if (item.heading.getBoundingClientRect().top <= activationY) {
								current = item.slug;
							} else {
								break;
							}
						}

						return current;
					};

					const refreshActive = () => setActive(pickActiveSlug());

					const observer = new IntersectionObserver(
						() => refreshActive(),
						{
							rootMargin: '0px 0px -70% 0px',
							threshold: [0, 1],
						},
					);

					for (const item of headings) {
						observer.observe(item.heading);
					}

					window.addEventListener('hashchange', refreshActive);
					window.addEventListener('resize', refreshActive, { passive: true });
					document.addEventListener('scroll', refreshActive, { passive: true });
					refreshActive();
				}
			}
		</script>
	</body>
</html>
