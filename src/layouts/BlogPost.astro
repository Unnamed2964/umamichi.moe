---
import { getCollection } from 'astro:content';
import ArticleTocScript from '../components/ArticleTocScript.astro';
import ArticleComments from '../components/ArticleComments';
import BaseHead from '../components/BaseHead.astro';
import SiteChromeScripts from '../components/SiteChromeScripts.astro';
import { ArticleLayout } from '../components/chakra/ArticleLayout';
import type { ArticleTag } from '../components/chakra/ArticleTags';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import type { CopyrightConfig } from '../lib/copyright';
import { buildDocsStructure, toTagHref, type SidebarNode } from '../lib/docs';

type LayoutData = {
	comment?: boolean;
	copyright?: CopyrightConfig;
	title?: string;
	description?: string;
	tags?: string[];
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: {
		src: string;
	};
};

type TocHeading = {
	depth: number;
	slug: string;
	text: string;
};

type PostListItem = {
	href: string;
	id: string;
	title: string;
};

function flattenSidebarDocs(nodes: SidebarNode[]): PostListItem[] {
	return nodes.flatMap((node) => {
		if (node.kind === 'doc') {
			return [{
				href: node.href,
				id: node.id,
				title: node.title,
			}];
		}

		return flattenSidebarDocs(node.children);
	});
}

const pageData: LayoutData = 'frontmatter' in Astro.props
	? Astro.props.frontmatter
	: Astro.props;
const headings = 'headings' in Astro.props ? (Astro.props.headings as TocHeading[]) : undefined;
const articleList = 'articleList' in Astro.props ? (Astro.props.articleList as PostListItem[]) : undefined;
const currentEntryId = 'currentEntryId' in Astro.props ? (Astro.props.currentEntryId as string) : undefined;

const title = pageData.title ?? SITE_TITLE;
const description = pageData.description ?? SITE_DESCRIPTION;
const { pubDate, updatedDate, heroImage } = pageData;
const tags: ArticleTag[] = (pageData.tags ?? []).map((tag) => ({
	href: toTagHref(tag),
	label: tag,
}));
const currentPath = Astro.url.pathname;
const routePath = currentPath.replace(/^\/+|\/+$/g, '');
const topLevelFolderPath = routePath.split('/').filter(Boolean)[0] ?? '';
const docs = await getCollection('docs');
const docsStructure = buildDocsStructure(docs);
const comment = currentEntryId
	? docsStructure.docDataById.get(currentEntryId)?.comment ?? pageData.comment
	: pageData.comment;
const copyright = currentEntryId
	? docsStructure.docDataById.get(currentEntryId)?.copyright ?? pageData.copyright
	: pageData.copyright;
const sidebarTree = docsStructure.topLevelFolderTrees.get(topLevelFolderPath);
const orderedPosts = sidebarTree ? flattenSidebarDocs(sidebarTree.children) : [];
const currentPostIndex = currentEntryId ? orderedPosts.findIndex((item) => item.id === currentEntryId) : -1;
const previousPost = currentPostIndex > 0 ? orderedPosts[currentPostIndex - 1] : undefined;
const nextPost = currentPostIndex >= 0 && currentPostIndex < orderedPosts.length - 1
	? orderedPosts[currentPostIndex + 1]
	: undefined;
const formattedPubDate = pubDate
	? new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(pubDate)
	: undefined;
const formattedUpdatedDate = updatedDate
	? new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(updatedDate)
	: undefined;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<ArticleLayout
			copyright={copyright}
			currentPostId={currentEntryId}
			currentPath={currentPath}
			headings={headings}
			navItems={docsStructure.topLevelNavItems}
			nextPost={nextPost}
			previousPost={previousPost}
			sidebarTree={sidebarTree}
			title={title}
			tags={tags}
			pubDate={formattedPubDate}
			updatedDate={formattedUpdatedDate}
			heroImage={heroImage ? { src: heroImage.src } : undefined}
		>
			<slot />
			{comment && <ArticleComments client:idle />}
		</ArticleLayout>

		<SiteChromeScripts />
		<ArticleTocScript />
	</body>
</html>
