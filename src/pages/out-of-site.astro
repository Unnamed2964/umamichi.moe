---
import BaseHead from '../components/BaseHead.astro';
---

<html lang="zh-CN">
	<head>
		<BaseHead
			title="即将离开本站"
			description="站外链接确认页：在浏览器内校验对称 MAC（hash）与可选的 Ed25519（sig）后，可选择继续访问目标地址。"
			disableTikkun
		/>
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body class="out-of-site-body">
		<main class="out-of-site-main">
			<h1 class="out-of-site-title">即将离开本站</h1>
			<p id="out-of-site-status" class="out-of-site-status" hidden></p>
			<p id="out-of-site-detail" class="out-of-site-detail" hidden>
				<code id="out-of-site-url" class="out-of-site-url"></code>
			</p>
			<p class="out-of-site-actions">
				<a id="out-of-site-proceed" class="secondary-button" href="#" hidden>继续访问</a>
				<button type="button" id="out-of-site-close" class="primary-button">关闭</button>
			</p>
		</main>
		<script>
			import { runOutOfSitePage } from '../lib/out-of-site-verify-client.ts';

			void runOutOfSitePage({
				ed25519SpkiB64: import.meta.env.PUBLIC_OUT_OF_SITE_ED25519_SPKI_B64 ?? '',
				outOfSiteLinkHmacKey: import.meta.env.PUBLIC_OUT_OF_SITE_LINK_HMAC_KEY ?? '',
			});
		</script>
	</body>
</html>

<style>
	.out-of-site-body {
		margin: 0;
		min-height: 100dvh;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--page-gutter, 16px);
		font-family: var(--font-ui);
		background: var(--theme-700);
		color: var(--site-fg);
	}

	.out-of-site-main {
		position: relative;
		z-index: 0;
		box-sizing: border-box;
		width: min(100%, 28rem);
		margin: 0;
		padding: clamp(1.5rem, 4vw, 1.8rem);
		background: var(--site-bg);
		border: 1px solid var(--site-border-strong);
	}

	.out-of-site-title {
		margin: 0 0 0.875rem;
		font-size: clamp(1.25rem, 2.8vw, 1.55rem);
		font-weight: var(--site-weight-ui);
		letter-spacing: -0.02em;
		line-height: 1.25;
	}

	.out-of-site-status {
		margin: 0;
		line-height: 1.65;
		font-size: 0.975rem;
	}

	.out-of-site-status.is-warning {
		color: var(--site-danger);
		font-weight: var(--site-weight-emphasis);
	}

	.out-of-site-detail {
		margin: 1rem 0 0;
	}

	.out-of-site-url {
		display: block;
		box-sizing: border-box;
		width: 100%;
		margin: 0;
		padding: 0.45em 0.55em;
		font-family: var(--font-code);
		font-size: 0.875em;
		line-height: 1.45;
		color: var(--site-fg);
		word-break: break-all;
		background: var(--site-surface-muted);
	}

	.out-of-site-actions {
		margin: 1.375rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
	}

	#out-of-site-close {
		margin-left: auto;
	}

	/* common-css `.secondary-button` sets `display: inline-flex`, which overrides `[hidden]`. */
	#out-of-site-proceed[hidden] {
		display: none !important;
	}

	.out-of-site-actions .primary-button,
	.out-of-site-actions .secondary-button,
	.out-of-site-actions .danger-button {
		min-width: 6rem;
	}

	.out-of-site-actions .secondary-button,
	.out-of-site-actions .danger-button {
		text-decoration: none;
	}

	.out-of-site-actions .secondary-button:hover,
	.out-of-site-actions .secondary-button:active,
	.out-of-site-actions .danger-button:hover,
	.out-of-site-actions .danger-button:active {
		text-decoration: none;
	}

	.out-of-site-actions .secondary-button.is-pending,
	.out-of-site-actions .secondary-button[aria-disabled='true'],
	.out-of-site-actions .danger-button.is-pending,
	.out-of-site-actions .danger-button[aria-disabled='true'] {
		opacity: 0.5;
		pointer-events: none;
		cursor: not-allowed;
		transform: none;
	}
</style>
