---
import { getCollection, type CollectionEntry } from 'astro:content';
import DocEntryPage from '../components/DocEntryPage.astro';
import GeneratedDocListPage from '../components/GeneratedDocListPage.astro';
import { buildDocsStructure, type FolderPageListItem, type GeneratedFolderPageData } from '../lib/docs';

type EntryRouteProps = {
	childItems?: FolderPageListItem[];
	entry: CollectionEntry<'docs'>;
};

type GeneratedRouteProps = {
	childItems: FolderPageListItem[];
	generatedPage: GeneratedFolderPageData;
};

type RouteProps = EntryRouteProps | GeneratedRouteProps;

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	const { routes } = buildDocsStructure(docs);

	return routes.map((route) => ({
		params: {
			slug: route.routePath || undefined,
		},
		props: route,
	}));
}

const props = Astro.props as RouteProps;
---

{'entry' in props ? (
	<DocEntryPage entry={props.entry} />
) : (
	<GeneratedDocListPage
		childItems={props.childItems}
		description={props.generatedPage.description}
		title={props.generatedPage.title}
	/>
)}