---
import { getEntry, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

const page = await getEntry('pages', 'friends');

if (!page) {
	throw new Error('Missing content entry: pages/friends');
}

const { Content } = await render(page);
---

<BlogPost {...page.data}>
	<Content />
</BlogPost>