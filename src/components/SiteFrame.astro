---
import MetroNavIcon from './MetroNavIcon.astro';
import PaletteDropdown from './PaletteDropdown.tsx';
import ThemeToggleButton from './ThemeToggleButton.astro';
import { SITE_TITLE } from '../consts';
import type { TopLevelNavItem } from '../lib/docs';
import { SITE_MAIN_MAX_W } from '../lib/site-layout';
import { getActiveNavIndex, getMetroNavIconTone, isActiveLink } from '../lib/site-frame';
import { SITE_ROUTE_TRANSITION_SCOPE } from '../lib/site-slide-transition';

interface Props {
	currentPath: string;
	navItems: TopLevelNavItem[];
}

const { currentPath, navItems } = Astro.props;
const activeNavIndex = getActiveNavIndex(navItems, currentPath);
const year = new Date().getFullYear();

const iconBars = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" aria-hidden="true" focusable="false"><path fill="currentColor" d="M0 96C0 78.3 14.3 64 32 64l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 128C14.3 128 0 113.7 0 96zM0 256c0-17.7 14.3-32 32-32l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 288c-17.7 0-32-14.3-32-32zM448 416c0 17.7-14.3 32-32 32L32 448c-17.7 0-32-14.3-32-32s14.3-32 32-32l384 0c17.7 0 32 14.3 32 32z"/></svg>`;

const iconX = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true" focusable="false"><path fill="currentColor" d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg>`;

const iconGithub = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 496 512" aria-hidden="true" focusable="false"><path fill="currentColor" d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"/></svg>`;
---

<div class="site-shell">
	<header
		class="site-header wpm-pane-shift"
		data-site-header
		data-lens-border="bottom"
		data-lens-depth="0.9"
		data-astro-transition-persist="header"
	>
		<div class="navbar-running-line" data-nav-running-line aria-hidden="true"></div>
		{
			navItems.map((item, index) => {
				const tone = getMetroNavIconTone(index, activeNavIndex);
				return (
					<span
						class="site-header__nav-icon"
						data-nav-icon
						data-nav-icon-current={tone === 'current' ? true : undefined}
						aria-hidden="true"
					>
						<MetroNavIcon kind={item.icon} tone={tone} />
					</span>
				);
			})
		}

		<div class="site-container site-container--frame">
			<div class="site-header__stack">
				<div class="site-header__row">
					<div class="site-header__mobile-bar">
						<button
							type="button"
							class="site-icon-button site-icon-button--round site-icon-button--bars"
							data-site-menu-toggle
							aria-label="打开菜单"
							aria-controls="site-mobile-menu"
							aria-expanded="false"
						>
							<Fragment set:html={iconBars} />
						</button>
						<h1 class="site-header__title site-header__title--mobile">
							<a class="site-header__title-link" href="/">{SITE_TITLE}</a>
						</h1>
					</div>

					<PaletteDropdown
						client:load
						wrapClassName="site-header__palette-dropdown--mobile"
						className="site-icon-button--round"
					/>
					<ThemeToggleButton class="site-header__theme-toggle--mobile site-icon-button--round" />

					<h1 class="site-header__title site-header__title--desktop">
						<a class="site-header__title-link" href="/">{SITE_TITLE}</a>
					</h1>

					<div class="site-header__desktop-bar">
						<nav class="site-header__nav" aria-label="主导航">
							{
								navItems.map((item) => {
									const active = isActiveLink(item.href, currentPath);
									return (
										<a
											class="site-header__nav-link"
											href={item.href}
											data-nav-item
											data-nav-active-item={active ? true : undefined}
											aria-current={active ? 'page' : undefined}
										>
											<span>{item.label}</span>
										</a>
									);
								})
							}
						</nav>

						<div class="site-header__actions">
							<PaletteDropdown client:load className="site-icon-button--round" />
							<ThemeToggleButton class="site-icon-button--round" />
							<a
								class="site-header__social-link"
								href="https://twitter.com/Umamichiz"
								target="_blank"
								rel="noreferrer"
								aria-label="X"
							>
								<Fragment set:html={iconX} />
							</a>
							<a
								class="site-header__social-link"
								href="https://github.com/Unnamed2964"
								target="_blank"
								rel="noreferrer"
								aria-label="GitHub"
							>
								<Fragment set:html={iconGithub} />
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</header>

	<div
		class="site-header-spacer"
		data-site-header-spacer
		aria-hidden="true"
	></div>

	<div
		class="site-mobile-dimmer wpm-pane-dimmer"
		data-site-mobile-dimmer
		aria-hidden="true"
	></div>

	<nav
		id="site-mobile-menu"
		class="site-mobile-menu wpm-pane-menu"
		aria-label="移动端菜单"
		aria-hidden="true"
		data-site-mobile-menu
		data-lens-border="right"
		data-lens-depth="1.1"
	>
		<div class="mobile-navbar-running-line" data-mobile-nav-running-line aria-hidden="true"></div>
		{
			navItems.map((item, index) => {
				const tone = getMetroNavIconTone(index, activeNavIndex);
				return (
					<span class="site-mobile-menu__nav-icon" data-mobile-nav-icon aria-hidden="true">
						<span class="site-mobile-menu__nav-icon-rotate">
							<MetroNavIcon kind={item.icon} tone={tone} />
						</span>
					</span>
				);
			})
		}

		<div class="site-mobile-menu__inner">
			<div class="site-mobile-menu__layout">
				<header class="site-mobile-menu__header">
					<button
						type="button"
						class="site-icon-button site-icon-button--round site-icon-button--bars"
						data-site-menu-close
						aria-label="关闭菜单"
					>
						<Fragment set:html={iconBars} />
					</button>
				</header>

				<div class="site-mobile-menu__nav-list" data-mobile-nav-list>
					<ul class="site-mobile-menu__links">
						{
							navItems.map((item) => {
								const active = isActiveLink(item.href, currentPath);
								return (
									<li class="site-mobile-menu__link-item">
										<a
											class="site-mobile-menu__link"
											data-site-menu-link
											data-mobile-nav-item
											data-mobile-nav-active-item={active ? true : undefined}
											href={item.href}
											aria-current={active ? 'page' : undefined}
										>
											<span>{item.label}</span>
										</a>
									</li>
								);
							})
						}
					</ul>
				</div>

				<footer class="site-mobile-menu__footer">
					<a
						class="site-header__social-link"
						href="https://twitter.com/Umamichiz"
						target="_blank"
						rel="noreferrer"
						aria-label="X"
					>
						<Fragment set:html={iconX} />
					</a>
					<a
						class="site-header__social-link"
						href="https://github.com/Unnamed2964"
						target="_blank"
						rel="noreferrer"
						aria-label="GitHub"
					>
						<Fragment set:html={iconGithub} />
					</a>
				</footer>
			</div>
		</div>
	</nav>

	<slot name="article-sidebar-left" />

	<slot name="article-sidebar-right" />

	{/*
	  Content pane-shift: menu push for main + footer.
	  Route VT stays on <main> only.
	*/}
	<div class="site-pane-shift wpm-pane-shift">
		<main
			class="site-main site-route-main"
			style={`max-width: ${SITE_MAIN_MAX_W}`}
			data-astro-transition-scope={SITE_ROUTE_TRANSITION_SCOPE}
		>
			<slot />
		</main>

		<footer class="site-footer" data-astro-transition-persist="footer">
			<div class="site-container site-container--frame">
				<div class="site-footer__stack">
					<p class="site-footer__line">
						<span>© {year} Umamichi/Unnamed2964.</span>
						<span>
							Powered by{' '}
							<a class="site-footer__link" href="https://astro.build/" target="_blank" rel="noreferrer">Astro</a>, Transitions powered by{' '}
							<a
								class="site-footer__link"
								href="https://github.com/umamichi-ui/windows-phone-motion"
								target="_blank"
								rel="noreferrer"
							>@umamichi-ui/windows-phone-motion</a>
							(<a
								class="site-footer__link"
								href="https://github.com/MicrosoftArchive/WindowsPhoneToolkit"
								target="_blank"
								rel="noreferrer"
							>Windows Phone Toolkit</a>).
						</span>
					</p>
				</div>
			</div>
		</footer>
	</div>

	{/*
	  Fixed viewport layer that also pane-shifts — keeps absolute FAB from jumping when
	  a document-flow ancestor gains transform (fixed containing-block switch).
	*/}
	<div class="site-floating-layer site-pane-shift wpm-pane-shift">
		<slot name="site-floating" />
	</div>
</div>
