---
import BlogPost from '../layouts/BlogPost.astro';
import FolderDocListView from './FolderDocListView.astro';
import type { FolderPageListItem } from '../lib/docs';

type Props = {
	childItems: FolderPageListItem[];
	description: string;
	title: string;
};

const { childItems, description, title } = Astro.props as Props;
---

<BlogPost title={title} description={description}>
	<p>这里收录了该目录下的文件与子目录，排序规则与左侧导航保持一致。</p>

	<FolderDocListView childItems={childItems} />
</BlogPost>