const observedMaxDots = 5;
const classes = ['windows-progress-ring', className, active ? 'is-active' : 'is-inactive'].filter(Boolean).join(' ');
---

<span
	class={classes}
	role="progressbar"
	aria-label={label}
	aria-valuetext={label}
	aria-busy={active ? 'true' : 'false'}
	data-solved-ring
	data-active={active ? 'true' : 'false'}
	data-frame-angles={JSON.stringify(observedFrameAngles)}
	style={{
		'--progress-ring-size': resolvedSize,
		'--progress-ring-foreground': foreground,
	}}
>
	<span class="progress-ring-stage" aria-hidden="true">
		{Array.from({ length: observedMaxDots }).map(() => (
			<span class="progress-ring-dot"></span>
		))}
	</span>
</span>

<script>
	const FPS = 30;
	const FRAME_COUNT = 116;
	const RADIUS_RATIO = 39.5;
	const parseFrameAngles = (raw: string | null | undefined) => {
		if (!raw) {
			return [];
		}
		try {
			const parsed = JSON.parse(raw);
			if (!Array.isArray(parsed)) {
				return [];
			}
			return parsed;
		} catch {
			return [];
		}
	};

	const rings = Array.from(document.querySelectorAll<HTMLElement>('[data-solved-ring]'));
	const states = rings
		.map((root) => ({
			active: root.dataset.active === 'true',
			frameAngles: parseFrameAngles(root.dataset.frameAngles),
			dots: Array.from(root.querySelectorAll<HTMLElement>('.progress-ring-dot')),
		}))
		.filter((state) => state.dots.length > 0 && state.frameAngles.length > 0);

	const paint = (state: (typeof states)[number], frameIndex: number) => {
		const angles = state.active ? state.frameAngles[frameIndex] ?? [] : [];
		state.dots.forEach((dot, index) => {
			const thetaDeg = angles[index];
			if (typeof thetaDeg !== 'number') {
				dot.style.opacity = '0';
				return;
			}
			const thetaRad = (thetaDeg * Math.PI) / 180;
			dot.style.left = `${50 + Math.cos(thetaRad) * RADIUS_RATIO}%`;
			dot.style.top = `${50 + Math.sin(thetaRad) * RADIUS_RATIO}%`;
			dot.style.opacity = '1';
		});
	};

	let rafId = 0;
	const tick = (timeMs: number) => {
		const frameIndex = Math.floor(((timeMs / 1000) * FPS) % FRAME_COUNT);
		states.forEach((state) => paint(state, frameIndex));
		rafId = window.requestAnimationFrame(tick);
	};

	if (states.length > 0) {
		rafId = window.requestAnimationFrame(tick);
		window.addEventListener(
			'beforeunload',
			() => {
				window.cancelAnimationFrame(rafId);
			},
			{ once: true },
		);
	}
</script>

<style>
	.windows-progress-ring {
		position: relative;
		display: inline-block;
		width: var(--progress-ring-size);
		height: var(--progress-ring-size);
	}

	.windows-progress-ring.is-inactive {
		opacity: 0;
	}

	.progress-ring-stage {
		position: relative;
		display: block;
		width: 100%;
		height: 100%;
	}

	.progress-ring-dot {
		position: absolute;
		width: clamp(0.18rem, calc(var(--progress-ring-size) * 0.09), 0.38rem);
		height: clamp(0.18rem, calc(var(--progress-ring-size) * 0.09), 0.38rem);
		border-radius: 999px;
		background: var(--progress-ring-foreground);
		transform: translate(-50%, -50%);
		opacity: 0;
	}

	.is-inactive .progress-ring-dot {
		opacity: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.progress-ring-dot {
			transition: none;
		}
	}
</style>