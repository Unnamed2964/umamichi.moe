---
import ArticleComments from './ArticleComments';
import { ArticleCopyright } from './article/ArticleCopyright';
import ArticleGitHistory from './article/ArticleGitHistory';
import { ArticleHeader } from './article/ArticleHeader';
import { ArticleHeroImage } from './article/ArticleHeroImage';
import { ArticlePostList } from './article/ArticlePostList';
import { ArticlePrevNext } from './article/ArticlePrevNext';
import ArticleSourceActions from './article/ArticleSourceActions';
import { ArticleTags } from './article/ArticleTags';
import ArticleMobileToc from './article/ArticleMobileToc';
import { ArticleToc } from './article/ArticleToc';
import SiteFrame from './SiteFrame.astro';
import type { AdjacentArticleLink, ArticleTag } from '../lib/article';
import {
	SITE_ARTICLE_SIDEBAR_LEFT_TRANSITION_SCOPE,
	SITE_ARTICLE_SIDEBAR_RIGHT_TRANSITION_SCOPE,
} from '../lib/site-slide-transition';
import { filterArticleTocHeadings, type ArticleTocHeading } from '../lib/article-toc';
import type { CopyrightConfig } from '../lib/copyright';
import type { SidebarFolderNode, TopLevelNavItem } from '../lib/docs';

interface Props {
	comment?: boolean;
	copyright?: CopyrightConfig;
	currentPath: string;
	currentPostId?: string;
	headings?: ArticleTocHeading[];
	heroImage?: {
		src: string;
	};
	historyUrl?: string;
	navItems: TopLevelNavItem[];
	nextPost?: AdjacentArticleLink;
	previousPost?: AdjacentArticleLink;
	pubDate?: string;
	readingTimeLabel?: string;
	sidebarTree?: SidebarFolderNode;
	sourceMarkdown?: string;
	sourceUrl?: string;
	tags?: ArticleTag[];
	title: string;
	updatedDate?: string;
}

const {
	comment = false,
	copyright,
	currentPath,
	currentPostId,
	headings = [],
	heroImage,
	historyUrl,
	navItems,
	nextPost,
	previousPost,
	pubDate,
	readingTimeLabel,
	sidebarTree,
	sourceMarkdown,
	sourceUrl,
	tags = [],
	title,
	updatedDate,
} = Astro.props;

const tocHeadings = filterArticleTocHeadings(headings);
const hasToc = tocHeadings.length > 0;
const hasSourceTools = Boolean(sourceUrl && sourceMarkdown);
const tocMaxHeight = hasSourceTools
	? 'calc(100vh - var(--site-header-offset) - 9rem)'
	: undefined;
---

<SiteFrame currentPath={currentPath} navItems={navItems}>
	{
		sidebarTree && (
			<aside
				slot="article-sidebar-left"
				class="article-layout__sidebar article-layout__sidebar--left"
				data-astro-transition-scope={SITE_ARTICLE_SIDEBAR_LEFT_TRANSITION_SCOPE}
			>
				<ArticlePostList
					currentPath={currentPath}
					currentPostId={currentPostId}
					tree={sidebarTree}
				/>
			</aside>
		)
	}

	{
		(hasToc || hasSourceTools) && (
			<aside
				slot="article-sidebar-right"
				class="article-layout__sidebar article-layout__sidebar--right"
			>
				<div class="article-sidebar-rail">
					{hasSourceTools && (
						<ArticleSourceActions
							sourceMarkdown={sourceMarkdown!}
							sourceUrl={sourceUrl!}
							historyUrl={historyUrl}
						/>
					)}
					{hasToc && (
						<div
							class="article-sidebar-rail__toc"
							data-astro-transition-scope={SITE_ARTICLE_SIDEBAR_RIGHT_TRANSITION_SCOPE}
						>
							<ArticleToc headings={tocHeadings} maxH={tocMaxHeight} />
						</div>
					)}
				</div>
			</aside>
		)
	}

	<div class="article-layout">
		<article class="article-page">
			<div class="article-page__stack">
				{sidebarTree && (
					<div class="article-layout__sidebar-mobile">
						<ArticlePostList
							currentPath={currentPath}
							currentPostId={currentPostId}
							tree={sidebarTree}
							variant="mobile"
						/>
					</div>
				)}

				<div class="article-page__meta article-page__block">
					<ArticleHeader
						title={title}
						pubDate={pubDate}
						readingTimeLabel={readingTimeLabel}
						updatedDate={updatedDate}
					/>

					{tags.length > 0 ? (
						<div class="article-page__meta-actions">
							<ArticleTags tags={tags} />

							{hasSourceTools && (
								<div class="article-layout__source-mobile">
									<ArticleSourceActions
										sourceMarkdown={sourceMarkdown!}
										sourceUrl={sourceUrl!}
										historyUrl={historyUrl}
									/>
								</div>
							)}
						</div>
					) : (
						hasSourceTools && (
							<div class="article-layout__source-mobile">
								<ArticleSourceActions
									sourceMarkdown={sourceMarkdown!}
									sourceUrl={sourceUrl!}
									historyUrl={historyUrl}
								/>
							</div>
						)
					)}
				</div>

				{heroImage && (
					<div class="article-page__block">
						<ArticleHeroImage src={heroImage.src} />
					</div>
				)}

				<div class="article-content">
					<slot />
				</div>

				{copyright && (
					<div class="article-page__block">
						<ArticleCopyright copyright={copyright} />
					</div>
				)}

				{(previousPost || nextPost) && (
					<div class="article-page__block">
						<ArticlePrevNext
							previousPost={previousPost}
							nextPost={nextPost}
							showDivider={!copyright}
						/>
					</div>
				)}

				{comment && <ArticleComments client:idle />}
			</div>
		</article>
	</div>

	{
		(hasToc || historyUrl) && (
			<div slot="site-floating">
				{hasToc && <ArticleMobileToc client:load headings={tocHeadings} />}
				{historyUrl && <ArticleGitHistory client:load historyUrl={historyUrl} />}
			</div>
		)
	}
</SiteFrame>
