---
import WindowsProgressRing from './WindowsProgressRing.astro';
import { SITE_GITHUB_ERROR_FLOW_SOURCE_URL } from '../consts';

interface Props {
	recoveryHref: string;
	recoveryLabel: string;
	requestPath: string;
	statusCode: number;
	statusDescription: string;
	statusTitle: string;
}

const { recoveryHref, recoveryLabel, requestPath, statusCode, statusDescription, statusTitle } = Astro.props;
---

<main
	class="error-experience"
	data-error-screen
	data-phase="collecting"
	data-status-code={String(statusCode)}
	data-status-title={statusTitle}
	data-request-path={requestPath}
>
	<section class="phase phase-collecting" data-phase-panel="collecting" aria-live="polite">
		<div class="phase-inner">
			<p class="phase-face">:(</p>
			<p class="phase-copy">你的访问遇到问题，需要重启。我们只是在收集一些错误信息，然后会尝试重新带你回到可用页面。(<span data-progress-value>0</span>% 完成)</p>
			<aside class="phase-meta" aria-label="错误详情">
				<p>如果你想了解更多，可以稍后在线搜索此错误：{statusCode} {statusTitle.toUpperCase()}</p>
				<p>请求地址：{requestPath}</p>
			</aside>
		</div>
	</section>

	<section class="phase phase-boot" data-phase-panel="boot" aria-live="polite">
		<div class="boot-shell">
			<div class="boot-stack">
				<div class="boot-brand">
					<img class="boot-logo" src="/favicon.ico" alt="站点图标" width="128" height="128" />
				</div>
				<div class="boot-loader-wrap">
					<!--
						The real Windows 8 startup circle could not be extracted as a reusable
						asset from the inspected boot media resources. The current substitute is
						based on the Windows Development Kit ProgressRing template, not on a
						successful bootmgr animation extraction.
					-->
					<WindowsProgressRing className="boot-loader" size={27.2} label="正在启动恢复环境" foreground="#ffffff" />
				</div>
				<p class="boot-status">正在启动恢复环境</p>
			</div>
		</div>
	</section>

	<section class="phase phase-choice" data-phase-panel="choice" aria-live="polite">
		<div class="choice-shell">
			<header class="choice-header">
				<h1 data-choice-heading hidden>选择一个选项</h1>
				<p class="choice-subtitle" data-choice-subtitle hidden>继续前，请先选择要执行的操作。</p>
				<p class="choice-description" data-choice-copy hidden>{statusDescription}</p>
			</header>

			<nav class="choice-actions" data-choice-actions hidden aria-label="恢复导航">
				<a class="choice-link" href="/">
					<span class="choice-link-arrow" aria-hidden="true">
						<svg viewBox="0 0 158 100" focusable="false">
							<path d="m 37,50 v 0 0 z m 0,0 v 0 z M 55,0 H 92 L 52,36 H 158 V 64 H 52 l 40,36 v 0 H 55 v 0 L 0,50 H 0 L 0,50 0,50 h 0 l 55,-50 z" fill="currentColor"/>
						</svg>
					</span>
					<span class="choice-link-copy">
						<strong>返回主页</strong>
						<span>离开恢复环境并回到站点入口</span>
					</span>
				</a>
				<a class="choice-link" href="/about/">
					<span class="choice-link-arrow" aria-hidden="true">
						<svg viewBox="0 0 158 100" focusable="false">
							<path d="m 37,50 v 0 0 z m 0,0 v 0 z M 55,0 H 92 L 52,36 H 158 V 64 H 52 l 40,36 v 0 H 55 v 0 L 0,50 H 0 L 0,50 0,50 h 0 l 55,-50 z" fill="currentColor"/>
						</svg>
					</span>
					<span class="choice-link-copy">
						<strong>前往关于页</strong>
						<span>查看站点说明与作者信息</span>
					</span>
				</a>
				<a class="choice-link" href={recoveryHref}>
					<span class="choice-link-arrow" aria-hidden="true">
						<svg viewBox="0 0 158 100" focusable="false">
							<path d="m 37,50 v 0 0 z m 0,0 v 0 z M 55,0 H 92 L 52,36 H 158 V 64 H 52 l 40,36 v 0 H 55 v 0 L 0,50 H 0 L 0,50 0,50 h 0 l 55,-50 z" fill="currentColor"/>
						</svg>
					</span>
					<span class="choice-link-copy">
						<strong>{recoveryLabel}</strong>
						<span>尝试回到 {requestPath} 附近仍然可用的页面</span>
						<span class="choice-link-meta">{recoveryHref}</span>
					</span>
				</a>
				<a class="choice-link choice-link-github" href={SITE_GITHUB_ERROR_FLOW_SOURCE_URL} target="_blank" rel="noreferrer">
					<span class="choice-link-arrow choice-link-arrow-github" aria-hidden="true">
						<svg viewBox="0 0 98 96" focusable="false">
							<path d="M49 0C21.922 0 0 21.922 0 49c0 21.658 14.037 40.037 33.488 46.52 2.45.455 3.345-1.064 3.345-2.362 0-1.167-.043-4.267-.067-8.377-13.62 2.96-16.495-6.563-16.495-6.563-2.228-5.66-5.44-7.165-5.44-7.165-4.448-3.041.337-2.98.337-2.98 4.919.346 7.508 5.05 7.508 5.05 4.37 7.49 11.465 5.325 14.263 4.073.444-3.166 1.711-5.326 3.112-6.55-10.874-1.237-22.307-5.438-22.307-24.205 0-5.347 1.913-9.716 5.048-13.141-.506-1.238-2.188-6.218.48-12.963 0 0 4.116-1.317 13.49 5.02 3.912-1.087 8.105-1.631 12.272-1.65 4.167.019 8.36.563 12.279 1.65 9.366-6.337 13.474-5.02 13.474-5.02 2.675 6.745.994 11.725.488 12.963 3.144 3.425 5.04 7.794 5.04 13.141 0 18.814-11.453 22.954-22.359 24.166 1.76 1.516 3.328 4.506 3.328 9.08 0 6.55-.059 11.833-.059 13.442 0 1.31.883 2.839 3.37 2.357C83.979 89.022 98 70.648 98 49 98 21.922 76.078 0 49 0Z" fill="currentColor"/>
						</svg>
					</span>
					<span class="choice-link-copy">
						<strong>往 GitHub</strong>
						<span>查看 Windows 恢复环境 UI Web 模拟的实现源码</span>
						<span class="choice-link-meta">src/components/ErrorRecoveryExperience.astro</span>
					</span>
				</a>
			</nav>
		</div>
	</section>
</main>



<script>
	import { createBaseTelemetryEvent, postTelemetry } from '../lib/client-telemetry';
	import { HESTER_SCHEMA_VERSION, SITE_ID } from '../lib/telemetry';

	(() => {
		const root = document.querySelector<HTMLElement>('[data-error-screen]');

		if (!root) {
			return;
		}

		const errorRoot = root;

		async function hester() {
			const event = {
				...createBaseTelemetryEvent(HESTER_SCHEMA_VERSION, SITE_ID),
				error: {
					statusCode: Number.parseInt(errorRoot.dataset.statusCode || '', 10) || null,
					statusTitle: errorRoot.dataset.statusTitle || null,
					requestPath: errorRoot.dataset.requestPath || null,
				},
			};

			await postTelemetry('/api/hester', event);
		}

		const progressValue = root.querySelector('[data-progress-value]');
		const choiceHeading = root.querySelector('[data-choice-heading]');
		const choiceSubtitle = root.querySelector('[data-choice-subtitle]');
		const choiceCopy = root.querySelector('[data-choice-copy]');
		const choicePath = root.querySelector('[data-choice-path]');
		const choiceActions = root.querySelector('[data-choice-actions]');
		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const progressDuration = 9000;
		const bootDuration = reducedMotion ? 120 : 4000;
		const choiceDelay = reducedMotion ? 40 : 120;
		const progressSteps = [0, 10, 30, 70, 100];

		const revealChoice = () => {
			root.dataset.phase = 'choice';
			choiceHeading?.removeAttribute('hidden');
			choiceSubtitle?.removeAttribute('hidden');
			choiceCopy?.removeAttribute('hidden');
			choicePath?.removeAttribute('hidden');
			choiceActions?.removeAttribute('hidden');
		};

		const startChoiceSequence = () => {
			root.dataset.phase = 'choice';
			window.setTimeout(revealChoice, choiceDelay);
		};

		const startBoot = () => {
			root.dataset.phase = 'boot';
			window.setTimeout(startChoiceSequence, bootDuration);
		};

		const runProgressSequence = () => {
			if (progressValue) {
				progressValue.textContent = String(progressSteps[0]);
			}

			progressSteps.slice(1).forEach((step, index, steps) => {
				const delay = index === steps.length - 1 ? progressDuration : (progressDuration * step) / 100;

				window.setTimeout(() => {
					if (progressValue) {
						progressValue.textContent = String(step);
					}

					if (step === 100) {
						window.setTimeout(startBoot, reducedMotion ? 30 : 90);
					}
				}, delay);
			});
		};

		hester();
		runProgressSequence();
	})();
</script>

<style>
	:global(html),
	:global(body) {
		min-height: 100%;
	}

	:global(body) {
		margin: 0;
		background: #000;
		color: #fff;
		font-family: 'Segoe UI', 'Noto Sans SC', 'Microsoft YaHei UI', sans-serif;
	}

	:global(body > .site-copy-toast) {
		display: none;
	}

	.error-experience {
		min-height: 100vh;
		background: #000;
		color: #fff;
	}

	.phase {
		position: fixed;
		inset: 0;
		opacity: 0;
		visibility: hidden;
		transition: opacity 120ms linear, visibility 0s linear 120ms;
	}

	.error-experience[data-phase='collecting'] .phase-collecting,
	.error-experience[data-phase='boot'] .phase-boot,
	.error-experience[data-phase='choice'] .phase-choice {
		opacity: 1;
		visibility: visible;
		transition-delay: 0s;
	}

	.phase-collecting {
		display: grid;
		align-items: start;
		background: #2067b2;
		padding: clamp(5.5rem, 16vh, 8.75rem) clamp(4rem, 11vw, 9rem) 3rem clamp(4.75rem, 15vw, 12rem);
		box-sizing: border-box;
	}

	.phase-inner {
		width: min(52rem, 100%);
	}

	.phase-face {
		margin: 0 0 2.8rem;
		font-size: clamp(6.4rem, 14.5vw, 10.75rem);
		font-weight: 200;
		line-height: 0.92;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.4rem, 6.7vw, 4.8rem);
		font-weight: 300;
		letter-spacing: -0.03em;
		line-height: 1.08;
	}

	.phase-copy {
		margin: 0;
		max-width: 45rem;
		font-size: clamp(1.95rem, 3.75vw, 2.35rem);
		font-weight: 300;
		letter-spacing: -0.018em;
		line-height: 1.28;
		color: rgba(255, 255, 255, 0.96);
	}

	.phase-meta {
		margin-top: 0.95rem;
		max-width: 47rem;
		font-size: clamp(1rem, 1.28vw, 1.08rem);
		font-weight: 300;
		line-height: 1.48;
		color: rgba(255, 255, 255, 0.9);
	}

	.phase-meta p {
		margin: 0;
		word-break: break-all;
	}

	.phase-meta p + p {
		margin-top: 0.2rem;
	}

	.phase-boot {
		display: block;
		background: #000;
	}

	.boot-shell {
		position: relative;
		min-height: 100vh;
		padding: 0 2rem;
		box-sizing: border-box;
	}

	.boot-stack {
		position: absolute;
		left: 50%;
		top: 38.5%;
		display: grid;
		justify-items: center;
		grid-auto-flow: row;
		gap: 0;
		transform: translate(-50%, 0);
	}

	.boot-brand {
		display: grid;
		place-items: center;
	}

	.boot-logo {
		display: block;
		width: 9.6rem;
		height: 9.6rem;
		border-radius: 0;
		image-rendering: pixelated;
		image-rendering: crisp-edges;
		shape-rendering: crispEdges;
	}

	.boot-loader-wrap {
		display: grid;
		place-items: center;
		width: 1.72rem;
		height: 1.72rem;
		margin-top: clamp(6.1rem, 14vh, 8.4rem);
	}

	:global(.boot-loader) {
		margin: 0;
	}

	.boot-status {
		margin: 0.55rem 0 0;
		font-size: 0.92rem;
		font-weight: 300;
		letter-spacing: 0.01em;
		color: rgba(255, 255, 255, 0.72);
		white-space: nowrap;
	}

	.phase-choice {
		display: grid;
		place-items: start;
		padding: clamp(3rem, 9vh, 5.8rem) clamp(2rem, 7vw, 5rem) clamp(2.8rem, 8vh, 4.8rem) clamp(4.5rem, 13vw, 9.75rem);
		box-sizing: border-box;
		background: #2067b2;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', 'Microsoft YaHei UI', sans-serif;
	}

	.choice-shell {
		width: min(30rem, 100%);
		display: grid;
		gap: 2rem;
		justify-self: start;
	}

	.choice-header {
		display: grid;
		gap: 0.38rem;
		justify-items: start;
		text-align: left;
	}

	.choice-header h1 {
		margin-bottom: 1.35rem;
		font-size: clamp(2.2rem, 4.6vw, 3.35rem);
		line-height: 1.04;
	}

	.choice-subtitle {
		margin: 0;
		word-break: break-word;
	}

	.choice-description,
	.choice-path {
		margin: 0;
		max-width: 40rem;
		word-break: break-word;
	}

	.choice-path {
		word-break: break-all;
	}

	.choice-actions {
		--choice-control-font-size: 0.9167rem;
		--choice-panel-width: 23.75rem;
		--choice-tile-size: 6.1rem;
		--choice-tile-gap: 1.06rem;
		--choice-inline-padding: 0.5rem;
		width: min(calc(var(--choice-panel-width) * 2 + 0.68rem), 100%);
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.68rem;
	}

	.choice-link {
		position: relative;
		display: block;
		min-height: 6.84rem;
		padding: 0.34rem var(--choice-inline-padding) 0.34rem calc(var(--choice-inline-padding) + var(--choice-tile-size) + var(--choice-tile-gap));
		border: none;
		border-radius: 0;
		background: transparent;
		color: #ffffff;
		text-decoration: none;
		transition: background-color 120ms ease, color 120ms ease;
	}

	.choice-link:hover,
	.choice-link:focus-visible {
		background: rgba(255, 255, 255, 0.12);
		outline: none;
	}

	.choice-link-arrow {
		display: grid;
		place-items: center;
		position: absolute;
		left: var(--choice-inline-padding);
		top: 50%;
		width: var(--choice-tile-size);
		height: var(--choice-tile-size);
		margin-top: 0;
		transform: translateY(-50%);
		border-radius: 0;
		background: #3fa9ea;
		box-sizing: border-box;
		color: #ffffff;
	}

	.choice-link-arrow svg {
		width: 2.86rem;
		height: auto;
		display: block;
		transform: rotate(180deg);
	}

	.choice-link-arrow-github {
		background: #3fa9ea;
	}

	.choice-link-arrow-github svg {
		width: 2.52rem;
		transform: none;
	}

	.choice-link-copy {
		display: grid;
		gap: 0.22rem;
		min-width: 0;
		align-content: start;
		padding-top: 0.46rem;
	}

	.choice-header h1,
	.choice-subtitle,
	.choice-description,
	.choice-path,
	.choice-link,
	.choice-link strong,
	.choice-link-copy span,
	.choice-link-meta {
		font-family: inherit;
	}

	.choice-subtitle,
	.choice-description,
	.choice-path {
		font-size: 0.95rem;
		font-weight: 300;
		line-height: 1.4;
		letter-spacing: 0;
		color: rgba(255, 255, 255, 0.88);
	}

	.choice-link strong {
		font-size: calc(var(--choice-control-font-size) * 1.296);
		font-weight: 300;
		letter-spacing: -0.015em;
		line-height: 1.08;
	}

	.choice-link-copy span,
	.choice-link-meta {
		font-size: calc(var(--choice-control-font-size) * 1.056);
		line-height: 1.28;
		color: rgba(255, 255, 255, 0.82);
	}

	.choice-link-meta {
		display: block;
		max-width: 100%;
		margin-top: 0.1rem;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		word-break: normal;
	}

	@media (min-width: 41rem) {
		.choice-shell {
			width: min(48.18rem, 100%);
		}

		.choice-actions {
			grid-auto-flow: column;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			grid-template-rows: repeat(3, auto);
		}
	}

	@media (max-width: 40rem) {
		.phase-collecting {
			padding: clamp(4rem, 12vh, 5rem) 1.75rem 2.5rem;
		}

		.phase-inner {
			width: min(24rem, 100%);
		}

		.phase-copy {
			max-width: 22rem;
			font-size: clamp(1.65rem, 7vw, 2rem);
			line-height: 1.3;
		}

		.phase-face {
			margin-bottom: 2rem;
			font-size: clamp(5.6rem, 18vw, 8.25rem);
		}

		.phase-meta {
			max-width: 22rem;
			font-size: 0.98rem;
			line-height: 1.5;
		}

		.choice-shell {
			width: min(22.5rem, 100%);
		}

		.phase-choice {
			padding: 2.25rem 1.75rem 2.75rem;
		}

		.boot-stack {
			top: 34%;
		}

		.boot-status {
			margin-top: 0.4rem;
			font-size: 0.88rem;
		}

		.boot-logo {
			width: 7.2rem;
			height: 7.2rem;
		}

		.boot-loader-wrap {
			width: 1.44rem;
			height: 1.44rem;
			margin-top: clamp(4.7rem, 11vh, 6rem);
		}

		.choice-link {
			--choice-panel-width: 22.5rem;
			--choice-tile-size: 5.22rem;
			--choice-tile-gap: 0.86rem;
			--choice-inline-padding: 0.34rem;
			min-height: 5.88rem;
			padding: 0.26rem var(--choice-inline-padding) 0.26rem calc(var(--choice-inline-padding) + var(--choice-tile-size) + var(--choice-tile-gap));
		}

		.choice-actions {
			width: min(calc(var(--choice-panel-width) - var(--choice-tile-size)), 100%);
		}

		.choice-link-arrow {
			width: var(--choice-tile-size);
			height: var(--choice-tile-size);
		}

		.choice-link-arrow svg {
			width: 2.42rem;
		}

		.choice-link strong {
			font-size: calc(var(--choice-control-font-size) * 1.18);
		}

		.choice-link-copy span,
		.choice-link-meta {
			font-size: calc(var(--choice-control-font-size) * 0.96);
		}

		.choice-link-copy {
			padding-top: 0.34rem;
		}

	}

	@media (prefers-reduced-motion: reduce) {
		.phase {
			transition: none;
		}

		.choice-link {
			transition: none;
		}
	}
</style>