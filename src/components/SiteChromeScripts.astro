<script>
	import { initOutOfSiteClickHandler } from '../lib/out-of-site-click-client.ts';

	initOutOfSiteClickHandler({
		outOfSiteLinkHmacKey: import.meta.env.PUBLIC_OUT_OF_SITE_LINK_HMAC_KEY ?? '',
	});
