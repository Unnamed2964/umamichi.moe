---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<div class="blog-post-list" aria-label="文章列表">
	{posts.map((post) => (
		<article class="blog-post-item">
			<a class="blog-post-link" href={`/blog/${post.id}/`}>
				<span class="blog-post-title">{post.data.title}</span>
				<time class="blog-post-date" datetime={post.data.pubDate.toISOString()}>
					{formatter.format(post.data.pubDate)}
				</time>
			</a>
		</article>
	))}
</div>

<style>
	.blog-post-list {
		margin-top: 1.5rem;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.blog-post-item {
		border-bottom: 1px solid rgba(0, 0, 0, 0.08);
	}

	.blog-post-link {
		display: flex;
		align-items: center;
		gap: 1rem;
		justify-content: space-between;
		padding: 0.6rem 0;
		color: inherit;
		text-decoration: none;
		transition: background-color 0.2s ease;
	}

	.blog-post-link:hover {
		text-decoration: none;
	}

	.blog-post-title {
		min-width: 0;
		font-size: 1.02em;
		font-weight: 500;
		line-height: 1.4;
		letter-spacing: -0.01em;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.blog-post-date {
		flex-shrink: 0;
		color: var(--chakra-colors-gray-500);
		font-size: 0.92em;
		font-weight: 600;
		line-height: 1.4;
		white-space: nowrap;
	}

	@media screen and (max-width: 47.99rem) {
		.blog-post-link {
			gap: 0.75rem;
		}

		.blog-post-title {
			font-size: 1em;
		}

		.blog-post-date {
			font-size: 0.84em;
		}
	}
</style>